---
import { t, type Locale } from '../data/site';
interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  class="grid h-7 w-7 place-items-center rounded-md transition-colors"
  style="color: var(--muted);"
  aria-label={t('toggle_theme', lang)}
  title={t('toggle_theme', lang)}
>
  <svg class="sun hidden h-[1.05rem] w-[1.05rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <svg class="moon hidden h-[1.05rem] w-[1.05rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  </svg>
</button>

<style>
  :global(html:not(.dark)) #theme-toggle .moon { display: block; }
  :global(html.dark) #theme-toggle .sun { display: block; }
  #theme-toggle:hover { color: var(--accent); }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var isDark = document.documentElement.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (e) {}
    });
  })();
</script>
