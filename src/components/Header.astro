---
import { withBase } from '../lib/url';
import { profile, t, localeName, locales, type Locale } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Locale;
  path: string;
}
const { lang, path } = Astro.props;

const nav = [
  { key: 'nav_home' as const, href: withBase(`${lang}`) },
  { key: 'nav_resume' as const, href: withBase(`${lang}/resume`) },
  { key: 'nav_articles' as const, href: withBase(`${lang}/articles`) },
];

function isActive(href: string): boolean {
  const norm = (s: string) => s.replace(/\/$/, '');
  const home = withBase(`${lang}`);
  if (norm(href) === norm(home)) return norm(path) === norm(home);
  return norm(path).startsWith(norm(href));
}

// Same page in the other locale: swap the first path segment after the base.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rest = path.replace(/\/$/, '').slice(base.length); // e.g. /en/resume
const otherLang: Locale = lang === 'en' ? 'pt' : 'en';
const swapped = rest.replace(/^\/(en|pt)(?=\/|$)/, `/${otherLang}`);
const altPath = `${base}${swapped || `/${otherLang}`}`;
---

<header class="border-b" style="border-color: var(--line);">
  <div class="page flex items-center justify-between gap-4 py-4">
    <a
      href={withBase(`${lang}`)}
      class="font-[var(--font-display)] text-[1.05rem] font-medium tracking-tight no-underline"
      style="color: var(--ink);"
    >
      {profile.shortName}<span style="color: var(--accent);">.</span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="mono rounded-md px-2 py-1 text-[0.74rem] uppercase tracking-[0.12em] no-underline transition-colors"
            style={`color: ${isActive(item.href) ? 'var(--accent)' : 'var(--muted)'};`}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {t(item.key, lang)}
          </a>
        ))
      }

      <span class="mx-1 h-4 w-px" style="background: var(--line);"></span>

      <a
        href={altPath}
        class="mono rounded-md px-2 py-1 text-[0.74rem] uppercase tracking-[0.12em] no-underline transition-colors"
        style="color: var(--muted);"
        aria-label={`Switch to ${localeName(otherLang)}`}
      >
        {localeName(otherLang)}
      </a>

      <ThemeToggle lang={lang} />
    </nav>
  </div>
</header>
