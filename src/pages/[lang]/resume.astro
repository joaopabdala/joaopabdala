---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';
import { profile, links, locales, isLocale, t, type Locale } from '../../data/site';
import {
  summary,
  experience,
  education,
  certifications,
  skills,
  languages,
  projects,
  resumePdf,
} from '../../data/resume';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Unknown locale: ${lang}`);
const locale = lang as Locale;
---

<BaseLayout title={t('nav_resume', locale)} description={summary[locale]} lang={locale}>
  <div class="container">
    <header class="reveal" style="display:flex; flex-wrap:wrap; align-items:flex-end; justify-content:space-between; gap:1rem; padding-bottom:1.4rem; border-bottom:1px solid var(--line-2);">
      <div>
        <p class="eyebrow">{profile.tagline[locale]}</p>
        <h1 class="title">{profile.name}</h1>
        <p class="mono" style="font-size:0.78rem; color:var(--muted); margin-top:0.6rem;">
          {profile.location[locale]} · <a href={links.email} style="color:var(--link); text-decoration:none;">{profile.email}</a>
        </p>
      </div>
      <a class="lang-toggle" href={withBase(resumePdf[locale])} download style="font-size:0.76rem; padding:0.5rem 0.9rem;">
        ↓ {t('resume_download', locale)}
      </a>
    </header>

    <p class="lede reveal" style="margin-top:1.6rem; animation-delay:50ms;">{summary[locale]}</p>

    <!-- Experience -->
    <section>
      <h2 class="section-label">{t('resume_experience', locale)}</h2>
      <div style="display:flex; flex-direction:column; gap:2rem; margin-top:1.4rem;">
        {
          experience.map((job) => (
            <div class="rsm-row">
              <div class="mono rsm-aside">{job.period[locale]}</div>
              <div>
                <h3 class="sans" style="font-size:1.15rem; color:var(--ink);">
                  {job.role[locale]} <span style="color:var(--accent);">·</span> {job.company}
                </h3>
                <p style="font-style:italic; color:var(--muted); font-size:0.92rem; margin-top:0.2rem;">{job.context[locale]}</p>
                <ul class="rsm-bullets">
                  {job.bullets[locale].map((b) => <li>{b}</li>)}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education + Certifications -->
    <div style="display:grid; gap:2.5rem; margin-top:0.5rem;" class="rsm-two">
      <section>
        <h2 class="section-label">{t('resume_education', locale)}</h2>
        <h3 class="sans" style="font-size:1.05rem; color:var(--ink); margin-top:1.2rem;">{education.degree[locale]}</h3>
        <p style="margin-top:0.2rem;">{education.school[locale]}</p>
        <p class="mono" style="font-size:0.74rem; color:var(--muted); margin-top:0.2rem;">{education.period[locale]}</p>
      </section>
      <section>
        <h2 class="section-label">{t('resume_certifications', locale)}</h2>
        <ul style="list-style:none; padding:0; margin:1.2rem 0 0;">
          {certifications[locale].map((c) => <li>{c}</li>)}
        </ul>
      </section>
    </div>

    <!-- Skills -->
    <section>
      <h2 class="section-label">{t('resume_skills', locale)}</h2>
      <dl style="display:flex; flex-direction:column; gap:0.9rem; margin-top:1.4rem;">
        {
          skills.map((row) => (
            <div class="rsm-row">
              <dt class="mono rsm-aside" style="text-transform:uppercase; letter-spacing:0.05em;">{row.label[locale]}</dt>
              <dd style="margin:0;">{row.items}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Showcase projects -->
    <section>
      <h2 class="section-label">{t('resume_projects', locale)}</h2>
      <div style="display:flex; flex-direction:column; gap:1.6rem; margin-top:1.4rem;">
        {
          projects.map((p) => (
            <div>
              <div class="work-head">
                <a class="work-title" href={p.url} target="_blank" rel="noopener">{p.name}</a>
                <span class="tags">{p.tags.join(' · ')}</span>
              </div>
              <p style="margin-top:0.35rem;">{p.summary[locale]}</p>
              {p.highlights[locale].length > 0 && (
                <ul class="rsm-bullets">
                  {p.highlights[locale].map((h) => <li>{h}</li>)}
                </ul>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Languages -->
    <section>
      <h2 class="section-label">{t('resume_languages', locale)}</h2>
      <ul style="list-style:none; padding:0; margin:1.4rem 0 0; display:grid; gap:0.7rem;" class="rsm-two">
        {
          languages.map((l) => (
            <li style="display:flex; align-items:baseline; gap:0.8rem;">
              <span class="sans" style="color:var(--ink);">{l.name[locale]}</span>
              <span style="flex:1; border-bottom:1px dotted var(--line-2);" />
              <span class="mono" style="font-size:0.74rem; color:var(--muted);">{l.level[locale]}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .rsm-row { display: grid; gap: 0.3rem; }
  .rsm-aside { color: var(--muted); font-size: 0.74rem; padding-top: 0.15rem; }
  .rsm-bullets { margin: 0.6rem 0 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .rsm-bullets li { padding-left: 0.2rem; }
  .rsm-bullets li::marker { color: var(--accent); }
  @media (min-width: 640px) {
    .rsm-row { grid-template-columns: 9.5rem 1fr; gap: 1.5rem; }
    .rsm-two { grid-template-columns: 1fr 1fr; }
  }
</style>
