---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { withBase } from '../../../lib/url';
import { locales, isLocale, t, type Locale } from '../../../data/site';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Unknown locale: ${lang}`);
const locale = lang as Locale;

const posts = (await getCollection('blog', (p) => p.data.lang === locale)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat(locale === 'pt' ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={t('articles_title', locale)} description={t('articles_intro', locale)} lang={locale}>
  <div class="container">
    <header class="reveal">
      <h1 class="title">{t('articles_title', locale)}</h1>
      <p class="lede">{t('articles_intro', locale)}</p>
    </header>

    <div class="reveal" style="animation-delay: 70ms; margin-top: 2rem; border-top: 1px solid var(--line);">
      {
        posts.length === 0 ? (
          <p class="mono" style="color: var(--muted); padding: 2.5rem 0;">{t('articles_empty', locale)}</p>
        ) : (
          <ul style="list-style: none; margin: 0; padding: 0;">
            {posts.map((post) => (
              <li>
                <a class="post-row" href={withBase(`${locale}/articles/${post.data.slug}`)} style="padding: 1.15rem 0;">
                  <time class="post-date" datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
                  <span>
                    <span class="post-title" style="display:block; font-size: 1.18rem;">{post.data.title}</span>
                    <span class="post-desc" style="display:block;">{post.data.description}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</BaseLayout>
