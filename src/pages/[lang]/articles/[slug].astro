---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { withBase } from '../../../lib/url';
import { isLocale, t, type Locale } from '../../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Unknown locale: ${lang}`);
const locale = lang as Locale;

const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat(locale === 'pt' ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description} lang={locale}>
  <div class="container">
    <a class="mono reveal" href={withBase(`${locale}/articles`)} style="font-size: 0.74rem; color: var(--muted); text-decoration: none; display: inline-block;">
      {t('article_back', locale)}
    </a>

    <header class="reveal" style="margin-top: 1.4rem; padding-bottom: 1.6rem; border-bottom: 1px solid var(--line); animation-delay: 50ms;">
      <time class="mono" style="font-size: 0.74rem; color: var(--accent);" datetime={post.data.date.toISOString()}>
        {dateFmt.format(post.data.date)}
      </time>
      <h1 class="title" style="margin-top: 0.6rem;">{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
    </header>

    {
      post.data.cover && (
        <img
          class="reveal article-cover"
          src={post.data.cover}
          alt={post.data.title}
          loading="eager"
          style="animation-delay: 80ms;"
        />
      )
    }

    <div class="prose reveal" style="margin-top: 2rem; animation-delay: 100ms;">
      <Content />
    </div>

    {
      post.data.originalUrl && (
        <footer style="margin-top: 2.5rem; padding-top: 1.4rem; border-top: 1px solid var(--line);">
          <a class="mono" href={post.data.originalUrl} target="_blank" rel="noopener" style="font-size: 0.8rem; color: var(--link); text-decoration: none;">
            {t('article_read_original', locale)}
          </a>
        </footer>
      )
    }
  </div>
</BaseLayout>
