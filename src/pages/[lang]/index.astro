---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';
import { profile, links, locales, isLocale, t, type Locale } from '../../data/site';
import { projects } from '../../data/resume';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Unknown locale: ${lang}`);
const locale = lang as Locale;

const posts = (await getCollection('blog', (p) => p.data.lang === locale))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat(locale === 'pt' ? 'pt-BR' : 'en-US', {
  year: 'numeric',
  month: 'short',
});

const social = [
  { label: 'GitHub →', href: links.github },
  { label: 'LinkedIn →', href: links.linkedin },
  { label: 'Substack →', href: links.substack },
  { label: 'Email →', href: links.email },
];
---

<BaseLayout title="" description={profile.bio[locale]} lang={locale}>
  <div class="container">
    <header class="reveal">
      <p class="eyebrow">{profile.tagline[locale]} · {profile.location[locale]}</p>
      <h1 class="title">{profile.name}</h1>
      <p class="lede">{profile.bio[locale]}</p>
      <div class="links-row">
        {
          social.map((s) => (
            <a href={s.href} rel={s.href.startsWith('mailto:') ? undefined : 'me noopener'} target={s.href.startsWith('mailto:') ? undefined : '_blank'}>
              {s.label}
            </a>
          ))
        }
      </div>
    </header>

    <section class="reveal" style="animation-delay: 70ms;">
      <h2 class="section-label">{t('home_featured_projects', locale)}</h2>
      <ul style="list-style: none; margin: 0; padding: 0;">
        {
          projects.map((p) => (
            <li class="work-item">
              <div class="work-head">
                <a class="work-title" href={p.url} target="_blank" rel="noopener">{p.name}</a>
                <span class="tags">{p.tags.join(' · ')}</span>
              </div>
              <p>{p.summary[locale]}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="reveal" style="animation-delay: 140ms;">
      <div style="display:flex; align-items:baseline; justify-content:space-between;">
        <h2 class="section-label" style="flex:1;">{t('home_latest_articles', locale)}</h2>
        <a class="mono" href={withBase(`${locale}/articles`)} style="font-size:0.72rem; color:var(--accent); text-decoration:none; margin-left:1rem;">
          {t('home_view_all_articles', locale)}
        </a>
      </div>
      <ul style="list-style: none; margin: 0; padding: 0;">
        {
          posts.map((post) => (
            <li>
              <a class="post-row" href={withBase(`${locale}/articles/${post.data.slug}`)}>
                <time class="post-date" datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
                <span>
                  <span class="post-title" style="display:block;">{post.data.title}</span>
                  <span class="post-desc" style="display:block;">{post.data.description}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
